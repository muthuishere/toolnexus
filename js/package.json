{
  "name": "toolnexus",
  "version": "0.8.0",
  "description": "Dynamic MCP servers + agent skills as uniform tools for any LLM (opencode-style).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --experimental-strip-types --test test/unit.test.ts",
    "example": "node --experimental-strip-types examples/basic.ts"
  },
  "keywords": [
    "mcp",
    "llm",
    "agent",
    "skills",
    "tools",
    "openai",
    "anthropic",
    "gemini"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/muthuishere/toolnexus.git"
  },
  "homepage": "https://github.com/muthuishere/toolnexus#readme",
  "bugs": {
    "url": "https://github.com/muthuishere/toolnexus/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
